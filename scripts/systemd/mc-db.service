[Unit]
Description=Mission Control Infrastructure (DB & Redis)
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/linus/openclaw-mission-control
ExecStart=/usr/local/bin/docker compose up -d db redis
ExecStop=/usr/local/bin/docker compose stop db redis

[Install]
WantedBy=default.target
